{
  "guid": "QCA767J8TyuShDZbBKPJJQ",
  "type": "Complex",
  "controller": "SAPB1.ProductionAddon.ProductionAddon.controller.certificatdialogDialog",
  "title": "{@@i18n>certificateDialogTitle}",
  "contentWidth": "900px",
  "contentHeight": "600px",
  "tabs": [
    {
      "guid": "SiDQgwlqQs25H1oFTVbHpA",
      "ctrlType": "b1.sdk.Section",
      "text": "{@@i18n>certificateDialogSectionTitle}",
      "subSections": [
        {
          "guid": "nuLSUm7ISea8Mq6WfdHk0g",
          "ctrlType": "b1.sdk.SubSection",
